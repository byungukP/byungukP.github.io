<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      {% if entry.studyType or entry.area %}
        <h6 class="title font-weight-bold mb-1">
          {% if entry.studyType %}{{ entry.studyType }}{% endif %}
          {% if entry.studyType and entry.area %} in {% endif %}
          {% if entry.area %}{{ entry.area }}{% endif %}
        </h6>
      {% endif %}

      {% if entry.institution %}
        <div class="mb-1">{{ entry.institution }}</div>
      {% endif %}

      <div class="text-muted mb-1">
        {% if entry.start_date %}
          {{ entry.start_date }}
        {% endif %}
        {% if entry.end_date %}
          - {{ entry.end_date }}
        {% endif %}
        {% if entry.location %}
          {% if entry.start_date or entry.end_date %} | {% endif %}{{ entry.location }}
        {% endif %}
      </div>

      {% if entry.highlights %}
        <ul class="items mb-0">
          {% for item in entry.highlights %}
            <li><span class="item">{{ item }}</span></li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
</ul>